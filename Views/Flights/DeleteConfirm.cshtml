@model Flight.Models.FlightModel

<h3>Are you sure you want to delete this flight?</h3>

<p>
    <strong>@Model.FlightNumber</strong> :
    @Model.FromCity → @Model.ToCity
</p>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="FlightNumber" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="List" class="btn btn-secondary">Cancel</a>
</form>